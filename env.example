# SeaTalk credentials and account policy do not require user-visible .env variables.
#
# Configure SeaTalk accounts under ~/.hermes/config.yaml instead. The account
# app_secret and signing_secret values live in config.yaml, so protect that file
# as secret-bearing configuration.
#
# Home channel follows Hermes' standard env contract. Use /sethome from SeaTalk
# or set these optional values in ~/.hermes/.env:
#
# SEATALK_HOME_CHANNEL=default:group/raw_seatalk_group_id
# SEATALK_HOME_CHANNEL_THREAD_ID=
#
# platforms:
#   seatalk:
#     enabled: true
#     extra:
#       accounts:
#         default:
#           enabled: true
#           app_id: your_app_id
#           app_secret: your_app_secret
#           signing_secret: your_signing_secret
#           mode: webhook
#           webhook_host: 0.0.0.0
#           webhook_port: 8080
#           webhook_path: /callback
#           dm_policy: allowlist
#           allow_from:
#             - alice@example.com
#           group_policy: open
#           group_allow_from:
#             - raw_seatalk_group_id
#           group_sender_allow_from:
#             - alice@example.com
#           processing_indicator: typing
