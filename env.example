# ~/.hermes/.env keeps only SeaTalk secrets.
SEATALK_APP_SECRET=your_app_secret
SEATALK_SIGNING_SECRET=your_signing_secret

# ~/.hermes/config.yaml keeps non-secret SeaTalk runtime policy.
#
# platforms:
#   seatalk:
#     enabled: true
#     extra:
#       app_id: your_app_id
#       mode: webhook
#       webhook_host: 0.0.0.0
#       webhook_port: 8080
#       webhook_path: /callback
#       home_channel: group/123
#       home_channel_name: SeaTalk Home
#       home_channel_thread_id:
#       dm_policy: allowlist
#       allow_from:
#         - alice@example.com
#         - bob@example.com
#       group_policy: open
#       group_allow_from:
#         - 123
#         - 456
#       group_sender_allow_from:
#         - alice@example.com
#         - bob@example.com
#       processing_indicator: typing
#       media_allow_hosts:
#         - openapi.seatalk.io
#       outbound_coalescing: true
#       outbound_coalescing_idle_seconds: 1.5
#       inbound_debounce_idle_seconds: 1.0
#       inbound_debounce_max_seconds: 5.0
#
# Relay mode replaces webhook listener settings with the relay URL:
#
#       mode: relay
#       relay_url: wss://relay.example.com/ws
